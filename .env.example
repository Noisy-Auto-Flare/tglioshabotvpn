# Bot Settings
BOT_TOKEN=your_bot_token_from_botfather
ADMIN_IDS=12345678,87654321 # Comma-separated Telegram IDs for service alerts

# Database Settings
DATABASE_URL=sqlite+aiosqlite:///./data/app.db

# VPN Settings (RemnaWave)
REMNAWAVE_API_URL=https://your-remnawave-instance.com/api
REMNAWAVE_API_KEY=your_remnawave_api_key
REMNAWAVE_COOKIE=your_remnawave_cookie
SUB_DOMAIN=https://sub.yourdomain.com
REMNAWAVE_DEFAULT_SQUAD_UUID=your_default_squad_uuid

# --- Payment Gateways ---

# 1. CryptoBot (@CryptoBot)
CRYPTOBOT_TOKEN=your_cryptobot_token

# 2. CryptoMus (cryptomus.com)
CRYPTOMUS_API_KEY=your_cryptomus_api_key
CRYPTOMUS_MERCHANT_ID=your_cryptomus_merchant_id

# 3. FreeKassa (SBP / Cards)
FREEKASSA_MERCHANT_ID=your_freekassa_merchant_id
FREEKASSA_SECRET_1=your_first_secret
FREEKASSA_SECRET_2=your_second_secret_for_webhooks

# 4. TON Connect / Manual TON
TON_WALLET_ADDRESS=UQXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
TON_PRICE_USD=6.0 # Current TON price in USD for automatic calculation
TONCENTER_API_KEY=your_toncenter_api_key_optional

# 5. Telegram Stars
STARS_CONVERSION_RATE=50 # 1 USD = 50 Stars

# Webhook Settings
USE_WEBHOOK=True
# Base URL for webhooks (e.g. https://api.yourdomain.com)
# The bot will append /api/v1/payments/... automatically in README instructions
WEBHOOK_URL=https://your-domain.com

# App Settings
DEBUG=False
LOG_LEVEL=INFO
