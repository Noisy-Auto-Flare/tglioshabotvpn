# Bot Settings
BOT_TOKEN=your_bot_token_from_botfather
ADMIN_IDS=12345678,87654321 # Comma-separated Telegram IDs

# Database Settings
DATABASE_URL=sqlite+aiosqlite:///./data/app.db

# VPN Settings (RemnaWave)
# Your RemnaWave instance URL (e.g., https://vpn.yourdomain.com/api)
REMNAWAVE_API_URL=https://your-remnawave-instance.com/api
# API Key generated in RemnaWave panel (Settings -> API Keys)
REMNAWAVE_API_KEY=your_remnawave_api_key

# Payment Settings (CryptoBot)
# Token from @CryptoBot (Create App -> API Token)
CRYPTOBOT_TOKEN=your_cryptobot_token
# Set to 'True' to use webhooks, 'False' to use background polling
USE_WEBHOOK=True
# URL for webhooks (must be HTTPS and accessible from internet)
# Example: https://api.yourdomain.com/api/v1/payments/cryptobot/webhook
WEBHOOK_URL=https://your-domain.com/api/v1/payments/cryptobot/webhook

# App Settings
DEBUG=False
LOG_LEVEL=INFO
