# Bot Settings
BOT_TOKEN=your_bot_token_from_botfather
ADMIN_IDS=12345678,87654321 # Comma-separated Telegram IDs

# Database Settings
DATABASE_URL=sqlite+aiosqlite:///./data/app.db

# VPN Settings (RemnaWave)
# Your RemnaWave instance URL (e.g., https://vpn.yourdomain.com/api)
REMNAWAVE_API_URL=https://your-remnawave-instance.com/api
# API Key generated in RemnaWave panel (Settings -> API Keys)
REMNAWAVE_API_KEY=your_remnawave_api_key
# Panel cookie (can expire; use a fresh value from browser if needed)
REMNAWAVE_COOKIE=your_remnawave_cookie
# Subscription domain for generated links (e.g., https://sub.yourdomain.com)
SUB_DOMAIN=https://sub.yourdomain.com
# UUID of Default-Squad for immediate assignment after user creation
REMNAWAVE_DEFAULT_SQUAD_UUID=your_default_squad_uuid

# Payment Settings (CryptoBot)
# Token from @CryptoBot (Create App -> API Token)
CRYPTOBOT_TOKEN=your_cryptobot_token
# Set to 'True' to use webhooks, 'False' to use background polling
USE_WEBHOOK=True
# URL for webhooks (must be HTTPS and accessible from internet)
# Example: https://api.yourdomain.com/api/v1/payments/cryptobot/webhook
WEBHOOK_URL=https://your-domain.com/api/v1/payments/cryptobot/webhook

# Telegram Stars Settings
# Approximate rate used in bot invoices: 1 USD = 50 Stars
STARS_CONVERSION_RATE=50

# TON Payment Settings (manual TON wallet payment flow)
# Your wallet address for direct TON transfers
TON_WALLET_ADDRESS=UQXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# Optional TonConnect manifest URL (reserved for future full TonConnect integration)
TONCONNECT_MANIFEST_URL=https://raw.githubusercontent.com/ton-connect/demo-dapp/main/public/tonconnect-manifest.json

# App Settings
DEBUG=False
LOG_LEVEL=INFO
